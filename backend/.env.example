# LazyBacktest 環境變數範例
# 複製此檔案為 .env 並填入實際值

# 資料庫連線
DATABASE_URL=postgresql://postgres:123qwe@localhost:5432/lazybacktest

# CORS 設定 (多個來源以逗號分隔)
BACKEND_CORS_ORIGINS=http://localhost:3123,http://localhost:5173,http://localhost:8000

# Redis (選填)
REDIS_URL=

# LINE Bot 設定 (問題回報通知)
# 請至 LINE Developers Console 取得這些值:
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_line_user_id_here
